# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gotogether?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_use_a_strong_random_string

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Email Configuration (Gmail SMTP) - Optional
# If not configured, emails will be skipped but API will continue to work
# To enable emails:
# 1. Enable 2FA on your Gmail account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
